# ═══════════════════════════════════════════════════════════════
# ForThePeople.in — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with actual secrets.
# ═══════════════════════════════════════════════════════════════

# ═══ Database (Neon PostgreSQL recommended) ═══
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ═══ Redis (Upstash — REST-based, required for Vercel serverless) ═══
# Uses @upstash/redis (NOT ioredis). Get from upstash.com
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your-upstash-rest-token

# ═══ AI Provider (OpenRouter — unified API gateway, 300+ models) ═══
OPENROUTER_API_KEY=your-openrouter-key

# ═══ External Data APIs ═══
DATA_GOV_API_KEY=your-data-gov-key
OPENWEATHER_API_KEY=your-openweather-key

# ═══ Payments (Razorpay) ═══
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx

# ═══ Admin & Security ═══
ADMIN_PASSWORD=change-this-to-a-strong-password
ENCRYPTION_SECRET=32-char-random-string-for-aes256
CRON_SECRET=random-string-for-cron-auth
TOTP_ENCRYPTION_KEY=random-string-for-totp

# Bearer secret for the one-shot /api/admin/seed-tenders endpoint.
# Generate fresh with: openssl rand -hex 32
# Delete after seeding production if you don't plan to re-seed.
SEED_SECRET=random-hex-for-tenders-seed-bearer-auth

# Salt for hashing voter IPs in /api/district-request (rate-limit key).
# Hashed IPs are never stored in the DB — used only as a Redis rate-limit
# key. Rotating this value resets the per-IP window. Generate with:
#   openssl rand -hex 32
VOTE_IP_SALT=

# ═══ Email (Resend) ═══
RESEND_API_KEY=re_xxxxxxxxxxxxx
ADMIN_EMAIL=your-email@example.com

# ═══ Admin Recovery (optional but recommended) ═══
ADMIN_RECOVERY_EMAIL=your-recovery-email@example.com
ADMIN_RECOVERY_PHONE=+91XXXXXXXXXX

# ═══ Analytics (Plausible — no cookies, DPDP-friendly) ═══
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=forthepeople.in
# Stats API (for pulling traffic data into admin panel). Different from the tracking script above.
# Generate at plausible.io → Settings → API Keys
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=forthepeople.in

# ═══ Admin IP Restriction (optional — comma-separated, leave empty to disable) ═══
ADMIN_ALLOWED_IPS=

# ═══ Error Monitoring (Sentry) ═══
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
# Stats API (for pulling unresolved errors into admin panel). DIFFERENT from SENTRY_AUTH_TOKEN.
# Generate at sentry.io → Settings → Account → API → Auth Tokens with scopes: event:read, project:read
SENTRY_API_TOKEN=
SENTRY_ORG=forthepeoplein
SENTRY_PROJECT=javascript-nextjs

# ═══ Site ═══
NEXT_PUBLIC_SITE_URL=https://forthepeople.in
NEXT_PUBLIC_SITE_NAME=ForThePeople.in
