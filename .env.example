# ═══════════════════════════════════════════════════════════════
# ForThePeople.in — Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file with actual secrets.
# ═══════════════════════════════════════════════════════════════

# ═══ Database (Neon PostgreSQL recommended) ═══
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ═══ Redis (Upstash — REST-based, required for Vercel serverless) ═══
# Uses @upstash/redis (NOT ioredis). Get from upstash.com
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your-upstash-rest-token

# ═══ AI Providers ═══
# Default: Anthropic Claude via OpusCode.pro proxy
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_BASE_URL=https://claude.opuscode.pro/api
# Fallback: Google Gemini
GEMINI_API_KEY=your-gemini-key

# ═══ External Data APIs ═══
DATA_GOV_API_KEY=your-data-gov-key
OPENWEATHER_API_KEY=your-openweather-key

# ═══ Payments (Razorpay) ═══
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx

# ═══ Admin & Security ═══
ADMIN_PASSWORD=change-this-to-a-strong-password
ENCRYPTION_SECRET=32-char-random-string-for-aes256
CRON_SECRET=random-string-for-cron-auth
TOTP_ENCRYPTION_KEY=random-string-for-totp

# ═══ Email (Resend) ═══
RESEND_API_KEY=re_xxxxxxxxxxxxx
ADMIN_EMAIL=your-email@example.com

# ═══ Admin Recovery (optional but recommended) ═══
ADMIN_RECOVERY_EMAIL=your-recovery-email@example.com
ADMIN_RECOVERY_PHONE=+91XXXXXXXXXX

# ═══ Analytics (Plausible — no cookies, DPDP-friendly) ═══
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=forthepeople.in

# ═══ Admin IP Restriction (optional — comma-separated, leave empty to disable) ═══
ADMIN_ALLOWED_IPS=

# ═══ Error Monitoring (Sentry) ═══
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ═══ Site ═══
NEXT_PUBLIC_SITE_URL=https://forthepeople.in
NEXT_PUBLIC_SITE_NAME=ForThePeople.in
