  expiryDate   DateTime?                          // Next renewal / expiry date — prefer over renewalDate
  autoRenew    Boolean   @default(true)
  accountEmail String?                            // Which email is logged in at the service

  // April 13, 2026 — subscription credentials (encrypted at rest)
  loginUsername    String?                        // Masked in UI; plain-text acceptable
  loginPassword    String?                        // AES-256-CBC encrypted via src/lib/encryption.ts
  loginMethod      String?                        // "email_password" | "google_sso" | "github_sso" | "api_key_only"
  loginNotes       String?                        // Free-form, e.g. "via Google SSO"

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([expiryDate])
  @@index([category])
}

model UpdateLog {
  id           String    @id @default(cuid())
  source       String                           // "admin_edit" | "scraper" | "cron" | "api" | "ai_bot"
  actorLabel   String?                           // "Admin" | "System" | username
  tableName    String                            // Prisma model name (e.g. "Leader")
  recordId     String
  action       String                            // "create" | "update" | "delete"
  fieldName    String?                           // Specific column changed (null for create/delete)
  oldValue     String?   @db.Text
  newValue     String?   @db.Text
  districtId   String?
  districtName String?
  moduleName   String?
  description  String?   @db.Text
  recordCount  Int?                              // Number of records affected (bulk ops)
  details      Json?                             // Structured diff / metadata
  timestamp    DateTime  @default(now())

  @@index([tableName, timestamp])
  @@index([districtId, timestamp])
  @@index([source, timestamp])
  @@index([moduleName, timestamp])
}

model AdminBotMessage {
  id           String    @id @default(cuid())
  role         String                            // "user" | "assistant"
  content      String    @db.Text
  action       String?                           // Matched pattern or "ai_call"
  actionResult Json?
  aiModel      String?
  aiCostUSD    Float     @default(0)
  timestamp    DateTime  @default(now())

  @@index([timestamp])
}

model PlatformReport {
  id           String   @id @default(cuid())
  type         String   @default("weekly")    // "weekly" | "manual"
  summary      String   @db.Text              // Plain-English health summary
  actionItems  Json                            // [{ priority, title, description }]
  metrics      Json                            // Snapshot of key metrics at generation time
  costTips     Json?                           // [{ tip, estimatedSaving, priority }]
  growthNotes  String?  @db.Text              // Free-form growth insights
  aiModel      String                          // Model used to generate
  aiProvider   String?                         // Provider used
  aiCostUSD    Float    @default(0)           // Approx generation cost
  generatedAt  DateTime @default(now())

  @@index([type, generatedAt])
}

model Expense {
  id               String    @id @default(cuid())
  date             DateTime
  category         String                          // "hosting" | "domain" | "ai_credits" | "development" | "design" | "marketing" | "legal" | "hardware" | "travel" | "salary" | "other"
  description      String
  amountINR        Float
  amountUSD        Float?
  exchangeRate     Float?                          // USD→INR rate on purchase date
  paymentMethod    String?                         // "upi" | "bank_transfer" | "card" | "cash" | "crypto" | "other"
  referenceNumber  String?
  invoiceUrl       String?                         // External link (Drive, etc.)
  invoiceBlobUrl   String?                         // Reserved for future Vercel Blob uploads
  isRecurring      Boolean   @default(false)
  recurringInterval String?                        // "monthly" | "quarterly" | "yearly"
  notes            String?
  createdBy        String    @default("admin")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([date])
  @@index([category])
}

// ═════════════════════════════════════════════════════════════════════════
// SupportPageConfig — singleton editable content for /support page.
// Admin can tweak bio copy, cost breakdown, and help-link list without a
// code deploy. Fallback defaults live in src/lib/support-defaults.ts.
// ═════════════════════════════════════════════════════════════════════════
model SupportPageConfig {
  id            String   @id @default("support-page-config")
  bioName       String   @default("Jayanth M B")
  bioSubtitle   String   @default("26 yr old · Entrepreneur from Mandya, Karnataka · Founder - ForThePeople.in")
  bioText       String   // markdown-ish; paragraphs separated by \n\n
  photoUrl      String   @default("/jayanth-profile.jpg")
  costBreakdown Json     @default("[]") // [{label, pct, color}]
  helpItems     Json     @default("[]") // [{label, desc, url, icon, external}]
  updatedAt     DateTime @updatedAt
}
