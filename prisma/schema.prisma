// ═══════════════════════════════════════════════════════════
// ForThePeople.in — Complete Prisma Schema (40+ models)
// Prisma 7 — connection URL in prisma.config.ts
// ═══════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══ CORE HIERARCHY ═══════════════════════════════════════

model State {
  id          String     @id @default(cuid())
  name        String
  nameLocal   String
  slug        String     @unique
  active      Boolean    @default(false)
  capital     String?
  districts   District[]
  governmentExams GovernmentExam[]
  supporters  Supporter[]
}

model District {
  id           String   @id @default(cuid())
  stateId      String
  state        State    @relation(fields: [stateId], references: [id])
  name         String
  nameLocal    String
  slug         String
  tagline      String?
  taglineLocal String?
  active       Boolean  @default(false)
  population   Int?
  area         Float?
  talukCount   Int?
  villageCount Int?
  literacy     Float?
  sexRatio     Int?
  density      Float?
  avgRainfall  Float?
  taluks       Taluk[]

  leaders            Leader[]
  infraProjects      InfraProject[]
  budgetEntries      BudgetEntry[]
  revenueEntries     RevenueEntry[]
  cropPrices         CropPrice[]
  weatherReadings    WeatherReading[]
  rainfallHistory    RainfallHistory[]
  populationHistory  PopulationHistory[]
  policeStations     PoliceStation[]
  trafficCollections TrafficCollection[]
  crimeStats         CrimeStat[]
  schemes            Scheme[]
  gramPanchayats     GramPanchayat[]
  rtiStats           RtiStat[]
  courtStats         CourtStat[]
  newsItems          NewsItem[]
  budgetAllocations  BudgetAllocation[]
  revenueCollections RevenueCollection[]
  damReadings        DamReading[]
  canalReleases      CanalRelease[]
  sugarFactories     SugarFactory[]
  serviceGuides      ServiceGuide[]
  citizenTips        CitizenTip[]
  localAlerts        LocalAlert[]
  govOffices         GovOffice[]
  electionResults    ElectionResult[]
  pollingBooths      PollingBooth[]
  busRoutes          BusRoute[]
  trainSchedules     TrainSchedule[]
  jjmStatuses        JJMStatus[]
  housingSchemes     HousingScheme[]
  powerOutages       PowerOutage[]
  schools            School[]
  soilHealthRecords  SoilHealth[]
  agriAdvisories     AgriAdvisory[]
  rtiTemplates        RtiTemplate[]
  famousPersonalities FamousPersonality[]
  feedbacks           Feedback[]
  localIndustries     LocalIndustry[]
  factCheckStatuses   FactCheckStatus[]
  moduleInsights      AIModuleInsight[]
  healthScore         DistrictHealthScore?
  newsActionQueue     NewsActionQueue[]
  governmentExams     GovernmentExam[]
  departmentStaffing  DepartmentStaffing[]
  supporters          Supporter[]

  @@unique([stateId, slug])
}

model Taluk {
  id           String   @id @default(cuid())
  districtId   String
  district     District @relation(fields: [districtId], references: [id])
  name         String
  nameLocal    String
  slug         String
  tagline      String?
  taglineLocal String?
  population   Int?
  area         Float?
  villageCount Int?
  villages     Village[]

  @@unique([districtId, slug])
}

model Village {
  id         String  @id @default(cuid())
  talukId    String
  taluk      Taluk   @relation(fields: [talukId], references: [id])
  name       String
  nameLocal  String?
  slug       String
  population Int?
  households Int?
  pincode    String?
  latitude   Float?
  longitude  Float?

  @@unique([talukId, slug])
}

// ═══ LEADERSHIP ═══════════════════════════════════════════

model Leader {
  id             String    @id @default(cuid())
  districtId     String
  district       District  @relation(fields: [districtId], references: [id])
  talukId        String?
  name           String
  nameLocal      String?
  role           String
  roleLocal      String?
  tier           Int
  party          String?
  constituency   String?
  phone          String?
  email          String?
  since          String?
  photoUrl       String?
  photoLicense   String?
  source           String?
  active           Boolean   @default(true)
  lastVerifiedAt   DateTime?
  roleDescription  String?

  @@index([districtId, tier])
  @@index([districtId, active])
}

// ═══ ELECTION EVENTS ══════════════════════════════════════

model ElectionEvent {
  id            String    @id @default(cuid())
  type          String    // LOK_SABHA | STATE_ASSEMBLY | MUNICIPAL | PANCHAYAT
  label         String
  state         String?   // state slug, null = national
  district      String?   // district slug, null = statewide
  lastHeld      DateTime?
  pollingDate   DateTime? // EXACT date if announced by ECI
  pollingPhases String?   // JSON: [{"phase":1,"date":"2026-04-23"}, ...]
  resultDate    DateTime?
  nextExpected  DateTime? // approximate when exact unknown
  termYears     Int       @default(5)
  totalSeats    Int?
  body          String    @default("Election Commission of India")
  note          String?
  source        String?   // URL: eci.gov.in notification
  isActive      Boolean   @default(true)
  updatedAt     DateTime  @updatedAt
  createdAt     DateTime  @default(now())

  @@index([state, isActive])
  @@index([type, isActive])
}

// ═══ INFRASTRUCTURE ═══════════════════════════════════════

model InfraProject {
  id            String    @id @default(cuid())
  districtId    String
  district      District  @relation(fields: [districtId], references: [id])
  talukId       String?
  name          String
  nameLocal     String?
  category      String
  budget        Float?
  fundsReleased Float?
  progressPct   Float?
  status        String
  contractor    String?
  startDate     DateTime?
  expectedEnd   DateTime?
  lat           Float?
  lng           Float?
  source        String?
  updatedAt     DateTime  @updatedAt

  // ── News-driven tracker (April 2026) ───────────────────────
  // Who announced & who runs it
  announcedBy         String?
  announcedByRole     String?
  party               String?
  executingAgency     String?
  keyPeople           Json?       // [{name, role, party, context}]

  // Budget lifecycle
  originalBudget      Float?
  revisedBudget       Float?
  costOverrun         Float?
  costOverrunPct      Float?

  // Timeline
  announcedDate       DateTime?
  approvedDate        DateTime?
  tenderDate          DateTime?
  actualStartDate     DateTime?
  originalEndDate     DateTime?
  revisedEndDate      DateTime?
  completionDate      DateTime?
  cancelledDate       DateTime?
  cancellationReason  String?
  delayMonths         Int?

  // Classification + news tracking
  shortName           String?
  description         String?     @db.Text  // 1-2 sentence citizen-focused summary
  scope               String?     @default("DISTRICT") // DISTRICT | STATE | NATIONAL
  sourceUrls          Json?
  lastNewsAt          DateTime?
  lastVerifiedAt      DateTime?
  verificationCount   Int?        @default(0)

  updates             InfraUpdate[]

  @@index([districtId, status])
  @@index([districtId, category])
  @@index([shortName])
  @@index([scope])
}

model InfraUpdate {
  id            String       @id @default(cuid())
  projectId     String
  project       InfraProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  date          DateTime
  headline      String
  summary       String?      @db.Text
  updateType    String       // ANNOUNCEMENT, APPROVAL, TENDER, CONSTRUCTION_START,
                              // BUDGET_INCREASE, BUDGET_DECREASE, DELAY, STALL,
                              // PROGRESS_UPDATE, CONTROVERSY, COMPLETION,
                              // CANCELLATION, PHASE_COMPLETE, INAUGURATION, REVIEW, SEED

  personName    String?
  personRole    String?
  personParty   String?

  budgetChange  Float?
  progressPct   Float?
  statusChange  String?

  newsUrl       String       // every update MUST link to a source
  newsTitle     String?
  newsSource    String?
  newsDate      DateTime?

  verified      Boolean      @default(false)
  verifiedAt    DateTime?

  createdAt     DateTime     @default(now())

  @@index([projectId, date])
  @@index([updateType])
  @@index([newsUrl])
}

// ═══ FINANCE & BUDGET ════════════════════════════════════

model BudgetEntry {
  id          String   @id @default(cuid())
  districtId  String
  district    District @relation(fields: [districtId], references: [id])
  fiscalYear  String
  sector      String
  sectorLocal String?
  allocated   Float
  released    Float
  spent       Float
  source      String?
  fetchedAt   DateTime @default(now())

  @@index([districtId, fiscalYear])
}

model BudgetAllocation {
  id              String   @id @default(cuid())
  districtId      String
  district        District @relation(fields: [districtId], references: [id])
  fiscalYear      String
  department      String
  departmentLocal String?
  scheme          String?
  category        String
  allocated       Float
  released        Float
  spent           Float
  lapsed          Float
  month           Int?
  quarter         Int?
  source          String
  sourceUrl       String?
  remarks         String?
  fetchedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([districtId, fiscalYear])
  @@index([districtId, department])
}

model RevenueEntry {
  id           String   @id @default(cuid())
  districtId   String
  district     District @relation(fields: [districtId], references: [id])
  fiscalYear   String
  month        Int
  taxRevenue   Float?
  centralGrant Float?
  stateGrant   Float?
  ownRevenue   Float?
  source       String?

  @@index([districtId, fiscalYear, month])
}

model RevenueCollection {
  id            String   @id @default(cuid())
  districtId    String
  district      District @relation(fields: [districtId], references: [id])
  fiscalYear    String
  month         Int
  category      String
  categoryLocal String?
  amount        Float
  target        Float?
  source        String
  fetchedAt     DateTime @default(now())

  @@index([districtId, fiscalYear, month])
}

// ═══ AGRICULTURE ══════════════════════════════════════════

model CropPrice {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  commodity  String
  variety    String?
  market     String
  minPrice   Float
  maxPrice   Float
  modalPrice Float
  arrivalQty Float?
  date       DateTime
  source     String
  fetchedAt  DateTime @default(now())

  @@index([districtId, commodity, date])
  @@index([date])
}

// ═══ WEATHER ══════════════════════════════════════════════

model WeatherReading {
  id          String   @id @default(cuid())
  districtId  String
  district    District @relation(fields: [districtId], references: [id])
  temperature Float?
  feelsLike   Float?
  humidity    Float?
  windSpeed   Float?
  windDir     String?
  conditions  String?
  rainfall    Float?
  pressure    Float?
  visibility  Float?
  source      String
  recordedAt  DateTime

  @@index([districtId, recordedAt])
}

model RainfallHistory {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  year       Int
  month      Int
  rainfall   Float
  normal     Float
  departure  Float
  source     String

  @@index([districtId, year, month])
}

// ═══ DEMOGRAPHICS ═════════════════════════════════════════

model PopulationHistory {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  year       Int
  population Int
  sexRatio   Int?
  literacy   Float?
  urbanPct   Float?
  density    Float?
  source     String

  @@index([districtId, year])
}

// ═══ POLICE ═══════════════════════════════════════════════

model PoliceStation {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  talukId    String?
  name       String
  nameLocal  String?
  address    String?
  phone      String?
  email      String?
  sho        String?
  lat        Float?
  lng        Float?

  @@index([districtId])
}

model TrafficCollection {
  id            String   @id @default(cuid())
  districtId    String
  district      District @relation(fields: [districtId], references: [id])
  date          DateTime
  challans      Int?
  amount        Float
  monthlyTarget Float?
  source        String?
  fetchedAt     DateTime @default(now())

  @@index([districtId, date])
}

model CrimeStat {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  year       Int
  category   String
  count      Int
  source     String

  @@index([districtId, year])
}

// ═══ SCHEMES ══════════════════════════════════════════════

model Scheme {
  id               String    @id @default(cuid())
  districtId       String?
  district         District? @relation(fields: [districtId], references: [id])
  name             String
  nameLocal        String?
  category         String
  amount           Float?
  beneficiaryCount Int?
  eligibility      String?
  applyUrl         String?
  level            String?
  active           Boolean   @default(true)
  source           String?
  updatedAt        DateTime  @updatedAt

  @@index([districtId, category])
}

// ═══ GRAM PANCHAYAT ═══════════════════════════════════════

model GramPanchayat {
  id            String   @id @default(cuid())
  villageId     String?
  talukId       String?
  districtId    String
  district      District @relation(fields: [districtId], references: [id])
  name          String
  nameLocal     String?
  population    Int?
  households    Int?
  waterCoverage Float?
  roadConnected Boolean?
  mgnregaWorks  Int?
  totalFunds    Float?
  fundsUtilized Float?
  source        String?
  updatedAt     DateTime @updatedAt

  @@index([districtId])
}

// ═══ RTI ══════════════════════════════════════════════════

model RtiStat {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  year       Int
  month      Int
  department String
  filed      Int
  disposed   Int
  pending    Int
  avgDays    Float?
  source     String

  @@index([districtId, year, month])
}

// ═══ JUDICIARY ════════════════════════════════════════════

model CourtStat {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  year       Int
  courtName  String
  filed      Int
  disposed   Int
  pending    Int
  avgDays    Float?
  source     String?

  @@index([districtId, year])
}

// ═══ NEWS ═════════════════════════════════════════════════

model NewsItem {
  id            String    @id @default(cuid())
  districtId    String?
  district      District? @relation(fields: [districtId], references: [id])
  title         String
  titleLocal    String?
  summary       String?
  url           String
  source        String
  category      String?
  publishedAt   DateTime
  fetchedAt     DateTime  @default(now())
  targetModule  String?   // e.g. "police", "infrastructure", "elections"
  moduleAction  String?   // e.g. "New SP appointed"
  classifiedBy  String?   // "opus", "gemini", "manual"
  classifiedAt  DateTime?

  @@index([districtId, publishedAt])
  @@index([publishedAt])
  @@index([targetModule])
}

// ═══ WATER & DAMS ═════════════════════════════════════════

model DamReading {
  id           String   @id @default(cuid())
  districtId   String
  district     District @relation(fields: [districtId], references: [id])
  damName      String
  damNameLocal String?
  waterLevel   Float
  maxLevel     Float
  storage      Float
  maxStorage   Float
  inflow       Float
  outflow      Float
  storagePct   Float
  recordedAt   DateTime
  source       String
  fetchedAt    DateTime @default(now())

  @@index([districtId, damName, recordedAt])
}

model CanalRelease {
  id             String   @id @default(cuid())
  districtId     String
  district       District @relation(fields: [districtId], references: [id])
  canalName      String
  canalNameLocal String?
  releaseCusecs  Float
  scheduledDate  DateTime
  duration       String?
  targetArea     String?
  source         String
  createdAt      DateTime @default(now())

  @@index([districtId, scheduledDate])
}

// ═══ LOCAL INDUSTRY ═══════════════════════════════════════

model LocalIndustry {
  id          String   @id @default(cuid())
  districtId  String
  district    District @relation(fields: [districtId], references: [id])
  name        String
  nameLocal   String?
  type        String   // e.g. "IT Park", "Heritage Site", "Manufacturing", "Tourism"
  category    String   // "IT Park" | "Manufacturing" | "Tourism" | "Heritage" | "Agriculture"
  location    String?
  taluk       String?
  latitude    Float?
  longitude   Float?
  details     Json?    // Flexible payload: {employees, area, companies, revenue, visitors, etc.}
  active      Boolean  @default(true)
  source      String?
  updatedAt   DateTime @updatedAt

  @@index([districtId, category])
  @@index([districtId, active])
}

model SugarFactory {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  name       String
  nameLocal  String?
  type       String
  location   String
  taluk      String?
  latitude   Float?
  longitude  Float?
  capacity   Float?
  phone      String?
  active     Boolean  @default(true)
  updatedAt  DateTime @updatedAt
  seasonData SugarFactorySeason[]
}

model SugarFactorySeason {
  id               String       @id @default(cuid())
  factoryId        String
  factory          SugarFactory @relation(fields: [factoryId], references: [id])
  season           String
  crushingStarted  DateTime?
  crushingEnded    DateTime?
  totalCaneCrushed Float?
  sugarProduced    Float?
  recoveryPct      Float?
  frpRate          Float?
  sapRate          Float?
  totalArrears     Float?
  farmersCount     Int?
  status           String
  source           String
  updatedAt        DateTime     @updatedAt
}

// ═══ SERVICE GUIDE ════════════════════════════════════════

model ServiceGuide {
  id               String    @id @default(cuid())
  districtId       String?
  district         District? @relation(fields: [districtId], references: [id])
  serviceName      String
  serviceNameLocal String?
  category         String
  office           String
  officeLocal      String?
  documentsNeeded  String[]
  fees             String?
  timeline         String?
  onlinePortal     String?
  onlineUrl        String?
  steps            String[]
  tips             String?
  active           Boolean   @default(true)
  updatedAt        DateTime  @updatedAt

  @@index([districtId, category])
}

// ═══ CITIZEN TIPS ═════════════════════════════════════════

model CitizenTip {
  id                 String   @id @default(cuid())
  districtId         String
  district           District @relation(fields: [districtId], references: [id])
  talukId            String?
  category           String
  categoryLocal      String?
  title              String
  titleLocal         String?
  description        String
  descriptionLocal   String?
  priority           Int      @default(0)
  icon               String?
  isDistrictSpecific Boolean  @default(false)
  seasonalMonths     Int[]
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@index([districtId, active])
}

// ═══ LOCAL ALERTS ═════════════════════════════════════════

model LocalAlert {
  id               String    @id @default(cuid())
  districtId       String
  district         District  @relation(fields: [districtId], references: [id])
  talukId          String?
  type             String
  title            String
  titleLocal       String?
  description      String
  descriptionLocal String?
  location         String?
  latitude         Float?
  longitude        Float?
  severity         String    @default("info")
  startDate        DateTime?
  endDate          DateTime?
  active           Boolean   @default(true)
  sourceUrl        String?
  autoGenerated    Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([districtId, active])
  @@index([districtId, severity])
}

// ═══ GOVERNMENT OFFICE DIRECTORY ══════════════════════════

model GovOffice {
  id              String   @id @default(cuid())
  districtId      String
  district        District @relation(fields: [districtId], references: [id])
  talukId         String?
  name            String
  nameLocal       String?
  department      String
  type            String
  address         String
  phone           String?
  email           String?
  website         String?
  headName        String?
  headDesignation String?
  latitude        Float?
  longitude       Float?
  mondayHours     String?
  tuesdayHours    String?
  wednesdayHours  String?
  thursdayHours   String?
  fridayHours     String?
  saturdayHours   String?
  sundayHours     String?
  lunchBreak      String?
  services        String[]
  holidays        String?
  notes           String?
  active          Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@index([districtId, type])
}

// ═══ ELECTIONS ════════════════════════════════════════════

model ElectionResult {
  id             String   @id @default(cuid())
  districtId     String
  district       District @relation(fields: [districtId], references: [id])
  year           Int
  electionType   String
  constituency   String
  winnerName     String
  winnerParty    String
  winnerVotes    Int
  runnerUpName   String?
  runnerUpParty  String?
  runnerUpVotes  Int?
  totalVoters    Int?
  votesPolled    Int?
  turnoutPct     Float?
  margin         Int?
  source         String

  @@index([districtId, year, electionType])
}

model PollingBooth {
  id           String   @id @default(cuid())
  districtId   String
  district     District @relation(fields: [districtId], references: [id])
  boothNumber  Int
  name         String
  location     String
  constituency String
  taluk        String?
  latitude     Float?
  longitude    Float?
  totalVoters  Int?

  @@index([districtId, constituency])
}

// ═══ TRANSPORT ════════════════════════════════════════════

model BusRoute {
  id            String   @id @default(cuid())
  districtId    String
  district      District @relation(fields: [districtId], references: [id])
  routeNumber   String?
  origin        String
  destination   String
  via           String?
  operator      String
  busType       String
  departureTime String?
  frequency     String?
  fare          Float?
  duration      String?
  active        Boolean  @default(true)

  @@index([districtId])
}

model TrainSchedule {
  id            String   @id @default(cuid())
  districtId    String
  district      District @relation(fields: [districtId], references: [id])
  trainNumber   String
  trainName     String
  origin        String
  destination   String
  stationName   String
  arrivalTime   String?
  departureTime String?
  daysOfWeek    String[]
  active        Boolean  @default(true)

  @@index([districtId])
}

// ═══ JAL JEEVAN MISSION ═══════════════════════════════════

model JJMStatus {
  id                 String   @id @default(cuid())
  districtId         String
  district           District @relation(fields: [districtId], references: [id])
  talukId            String?
  villageName        String?
  totalHouseholds    Int
  tapConnections     Int
  coveragePct        Float
  waterQualityTested Boolean  @default(false)
  waterQualityResult String?
  source             String
  updatedAt          DateTime @updatedAt

  @@index([districtId, talukId])
}

// ═══ HOUSING ══════════════════════════════════════════════

model HousingScheme {
  id             String   @id @default(cuid())
  districtId     String
  district       District @relation(fields: [districtId], references: [id])
  talukId        String?
  schemeName     String
  fiscalYear     String
  targetHouses   Int
  sanctioned     Int
  completed      Int
  inProgress     Int
  fundsAllocated Float?
  fundsReleased  Float?
  fundsSpent     Float?
  source         String
  updatedAt      DateTime @updatedAt

  @@index([districtId, schemeName])
}

// ═══ POWER ════════════════════════════════════════════════

model PowerOutage {
  id         String   @id @default(cuid())
  districtId String
  district   District @relation(fields: [districtId], references: [id])
  talukId    String?
  area       String
  type       String
  reason     String?
  startTime  DateTime
  endTime    DateTime?
  duration   String?
  source     String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([districtId, startTime])
  @@index([districtId, active])
}

// ═══ SCHOOLS ══════════════════════════════════════════════

model School {
  id                  String       @id @default(cuid())
  districtId          String
  district            District     @relation(fields: [districtId], references: [id])
  talukId             String?
  name                String
