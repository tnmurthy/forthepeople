// ═══ MULTI-USER ADMIN (foundation — per-user auth is future work) ══════
// AdminAuth (below) is still the singleton auth record used by the cookie-based login.
// AdminUser is the roster for future per-user auth + role-based UI filtering.
model AdminUser {
  id              String    @id @default(cuid())
  username        String    @unique
  email           String?   @unique
  passwordHash    String                             // bcryptjs hash
  role            String    @default("viewer")       // "owner" | "admin" | "viewer"
  permissions     Json      @default("[]")           // Array of tab slugs (empty = use role defaults)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  lastLoginIP     String?
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime?
  totpSecret      String?
  totpEnabled     Boolean   @default(false)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  auditLogs       AdminAuditLog[]

  @@index([username])
  @@index([role])
}

model AdminAuditLog {
  id              String     @id @default(cuid())
  adminUserId     String?
  adminUser       AdminUser? @relation(fields: [adminUserId], references: [id])
  actorLabel      String?                             // "admin" (legacy) or AdminUser.username
  action          String                              // "login" | "view_key" | "add_expense" | ...
  resource        String?                             // Table/resource name
  resourceId      String?
  details         Json?
  ipAddress       String?
  userAgent       String?
  timestamp       DateTime   @default(now())

  @@index([adminUserId, timestamp])
  @@index([action, timestamp])
  @@index([resource, timestamp])
}

model AdminAuth {
  id                  String    @id @default("admin")
  totpSecret          String?               // TOTP secret (encrypted)
  totpEnabled         Boolean   @default(false)
  totpVerifiedAt      DateTime?
  recoveryEmail       String    @default("")
  recoveryPhone       String    @default("")
  recoveryToken       String?               // Hashed one-time recovery token
  recoveryTokenExpiry DateTime?
  backupCodes         String?               // JSON array of encrypted one-time backup codes
  lastLoginAt         DateTime?
  lastLoginIp         String?
  failedAttempts      Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

