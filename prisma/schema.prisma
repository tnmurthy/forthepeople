  stateId          String?
  state            State?    @relation(fields: [stateId], references: [id])
  districtId       String?
  district         District? @relation(fields: [districtId], references: [id])

  title            String
  department       String
  vacancies        Int?
  qualification    String?
  ageLimit         String?   // e.g. "18-25 yrs (+3 OBC)"
  applicationFee   String?   // e.g. "Gen: ₹500, SC/ST: Free"
  selectionProcess String?   // e.g. "Prelims -> Mains -> Interview"
  payScale         String?   // e.g. "Level 6: ₹35,400"

  applyUrl         String?   // Genuine official link
  notificationUrl  String?   // Official PDF
  syllabusUrl      String?

  status           String    @default("upcoming") // legacy: "upcoming"/"open"/"closed"/"results"
                                                  // new (news-sourced): NOTIFICATION_OUT/APPLICATIONS_OPEN/
                                                  // APPLICATIONS_CLOSED/ADMIT_CARD_OUT/EXAM_SCHEDULED/
                                                  // RESULT_PENDING/RESULT_OUT/COMPLETED
  announcedDate    DateTime?
  startDate        DateTime? // = applicationStartDate
  endDate          DateTime? // = applicationEndDate
  admitCardDate    DateTime?
  examDate         DateTime?
  resultDate       DateTime?

  // ── News-driven sync (April 2026) ──────────────────────
  shortName         String?    // "UPSC CSE 2026" for fuzzy upsert matching
  organizingBody    String?    // "UPSC" / "SSC" / "MPSC" — populated alongside department
  category          String?    // CENTRAL | STATE_PSC | BANKING | RAILWAY | DEFENCE | TEACHING | OTHER
  scope             String?    @default("NATIONAL") // NATIONAL | STATE
  notificationDate  DateTime?  // distinct from announcedDate — when govt released the notification
  sourceUrls        Json?      // Array of news URLs that fed this exam
  lastVerifiedAt    DateTime?  // When a news article most recently confirmed this exam
  needsVerification Boolean   @default(false)       // Daily cron flags stale exams

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([stateId, status])
  @@index([districtId, status])
  @@index([shortName])
  @@index([scope])
}

