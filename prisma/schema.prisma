  billingCycle String    @default("monthly")
  renewalDate  DateTime?                          // Legacy — use expiryDate going forward
  status       String    @default("active")
  apiKeyEnvVar String?
  dashboardUrl String?
  notes        String?

  // April 2026 — finance system additions
  serviceName  String?   @unique                  // Stable machine identifier: "vercel_pro", "openrouter", etc.
  displayName  String?                            // Human-readable name; falls back to `name` if null
  plan         String?                            // "Free" | "Pro" | "Business" | "Usage-based"
